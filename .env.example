# Copy to `.env` and adjust. See docs/LOCAL_DEV.md and INFERENCE_BACKEND.md.

# --- Nest API (default 8080) ---
# API_PORT=8080

# --- llama.cpp `llama-server` OpenAI-compatible HTTP (default when env unset: http://127.0.0.1:8081) ---
# Keep this on a different port than the API to avoid clashes.
# MALV_LOCAL_INFERENCE_ENABLED=true
# MALV_LOCAL_INFERENCE_BASE_URL=http://127.0.0.1:8081
# MALV_LOCAL_INFERENCE_MODEL=your-model-id

# --- Beast-worker FastAPI (orchestration; not the model server — default 9090) ---
# Must NOT be the same URL as MALV_LOCAL_INFERENCE_BASE_URL (llama-server has no POST /v1/infer).
# BEAST_WORKER_BASE_URL=http://127.0.0.1:9090
# BEAST_WORKER_PORT=9090

# --- Worker → API (inference config pull; API default port 8080) ---
# MALV_API_BASE_URL=http://127.0.0.1:8080

# --- Primary GPU / remote OpenAI-compatible inference (env-first; served to beast-worker as effective config) ---
# MALV_INFERENCE_PROVIDER=openai_compatible
# MALV_INFERENCE_BASE_URL=https://your-pod.example/v1
# MALV_INFERENCE_MODEL=Qwen2.5-7B-Instruct
# MALV_INFERENCE_API_KEY=
# `env` = process env is the only runtime authority for that chain (admin DB override cannot apply).
# unset or `db_compat` = legacy: a valid enabled DB admin override may still win over env.
# MALV_INFERENCE_PRIMARY_AUTHORITY=env

# --- When beast-worker uses llamacpp backend (llama-server host; default 8081) ---
# MALV_LLAMACPP_BASE_URL=http://127.0.0.1:8081

# --- MALV validation / staged launch controls ---
# Enable validation telemetry surfaces (admin-only summary endpoint and validation turn logs).
# MALV_VALIDATION_MODE=true
# Optional verbose validation logging.
# MALV_TRACE_VERBOSE=false
# Keep truthful WS phase progress projection enabled (safe default true).
# MALV_WS_PHASE_PROGRESS_ENABLED=true
# Tag traffic as load-test validation traffic.
# MALV_LOAD_TEST_MODE=false

# --- MALV rollout gating ---
# Restrict MALV to internal IDs during staged validation.
# MALV_INTERNAL_USERS_ONLY_MODE=false
# MALV_INTERNAL_USER_IDS=user-id-1,user-id-2
# MALV_VALIDATION_ROLLOUT_PERCENT=100

# --- MALV learning controls for validation ---
# MALV_LEARNING_ENABLED=true
# MALV_FORCE_GLOBAL_LEARNING_ONLY=false
# MALV_DISABLE_REFINEMENT_FOR_TESTING=false

# --- MALV adaptive chat output token budgeting ---
# Defaults preserve current behavior when unset.
# MALV_CHAT_MAXTOKENS_MIN=320
# MALV_CHAT_MAXTOKENS_BASE=640
# MALV_CHAT_MAXTOKENS_MAX=2048
# MALV_CHAT_MAXTOKENS_STRUCTURED_BOOST=220
# MALV_CHAT_MAXTOKENS_CONVERSATION_BOOST=28
# MALV_CHAT_MAXTOKENS_BREVITY_PENALTY=120

# --- Failure simulation toggles (validation mode required) ---
# MALV_SIMULATE_LEARNING_HYDRATION_TIMEOUT=false
# MALV_SIMULATE_LOCAL_INFERENCE_UNAVAILABLE=false
# MALV_SIMULATE_WORKER_FALLBACK=false
# MALV_SIMULATE_DEFERRED_LEARNING_CAPTURE_FAILURE=false
# MALV_SIMULATE_WS_CALLBACK_ABSENT=false
# MALV_SIMULATE_POLICY_BLOCK=false
# MALV_SIMULATE_SLOW_PHASE_COMPLETION=false

# --- Universal capability: real web + finance retrieval ---
# Brave Search API (https://api.search.brave.com) — required for web_research, image_enrichment, and mixed visual/source routes.
# MALV_BRAVE_SEARCH_API_KEY=
# When true, disables Brave search and HTML snippet fetch (finance quotes still attempt unless disabled below).
# MALV_WEB_RETRIEVAL_DISABLED=false
# When true, skips CoinGecko / Yahoo finance HTTP used for finance_data and mixed finance legs.
# MALV_FINANCE_QUOTES_DISABLED=false
# Optional tuning for outbound fetch (defaults are safe for production).
# MALV_WEB_FETCH_TIMEOUT_MS=8000
# MALV_WEB_SEARCH_COUNT=8
