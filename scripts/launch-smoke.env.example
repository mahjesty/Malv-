MALV_SMOKE_BASE_URL=https://staging-api.example.com

# Primary staging user (existing or auto-signup)
MALV_SMOKE_USER_EMAIL=launch-smoke-a@example.test
MALV_SMOKE_USER_PASSWORD=ChangeMe_12345!
MALV_SMOKE_USER_A_NEW_PASSWORD=ChangeMe_67890!

# Secondary user for room isolation checks
MALV_SMOKE_USER_B_EMAIL=launch-smoke-b@example.test
MALV_SMOKE_USER_B_PASSWORD=ChangeMe_12345!

# Optional: enables full password reset -> stale session rejection check.
# If absent, reset-revoke step is marked skipped (non-blocking partial).
MALV_SMOKE_PASSWORD_RESET_TOKEN=

# Optional tuning
MALV_SMOKE_CALL_RECAP_POLL_ATTEMPTS=12
MALV_SMOKE_CALL_RECAP_POLL_INTERVAL_MS=2000
MALV_SMOKE_OUTPUT_DIR=artifacts/launch-smoke
