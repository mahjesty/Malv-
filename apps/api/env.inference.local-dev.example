# -----------------------------------------------------------------------------
# Local CPU chat via API → llama.cpp (OpenAI-compatible wire) on this machine.
# Merge these into repo ROOT .env and/or apps/api/.env (api .env overrides root).
# Loaded before Nest boots: apps/api/src/envload.ts
#
# Prefer MALV_LOCAL_CPU_INFERENCE_*; legacy MALV_LOCAL_INFERENCE_* still works.
# Beast-worker primary chain uses MALV_INFERENCE_* / INFERENCE_* (see env.inference.runpod.example).
# -----------------------------------------------------------------------------

MALV_LOCAL_CPU_INFERENCE_ENABLED=true
# Optional: forbid API→local CPU for chat even if enabled (belt-and-suspenders for prod)
# MALV_LOCAL_CPU_INFERENCE_DISABLE_CHAT_PATH=false
MALV_LOCAL_CPU_INFERENCE_BASE_URL=http://127.0.0.1:8081
MALV_LOCAL_CPU_INFERENCE_MODEL=qwen2.5-1.5b-instruct.gguf

# CPU-only dev: chat tier gating treats GPU as off so local CPU stays eligible.
MALV_GPU_TIER_ENABLED=false

# Optional: when GPU tier is enabled, use real worker health for reachability
# MALV_GPU_TIER_PROBE_WORKER_HEALTH=true

# Keep remote RunPod / OpenAI-compatible on the WORKER only if you still run infer there;
# it does not override API-side local inference when the vars above are set.

# Internal MALV agent task router (CPU/GPU-aware plans; attaches to Beast context when on).
# MALV_AGENT_SYSTEM_ENABLED=1
# MALV_AGENT_CHAT_ROUTER_CONTEXT=1

# --- Tier capability profiles (CPU sidecar vs GPU/primary chain) ---
# Routing compares task + agent-plan demand against these — not model file names.
# Raise classes / limits when moving to stronger Namecheap/live CPU or GPU without code changes.
#
# MALV_CPU_TIER_CAPABILITY_CLASS=standard
# MALV_CPU_TIER_MAX_PROMPT_CHARS=6000
# MALV_CPU_TIER_MAX_CONTEXT_CHARS=24000
# MALV_CPU_TIER_REASONING_DEPTH_MAX=deep
# MALV_CPU_TIER_LATENCY_PROFILE=interactive
# MALV_CPU_TIER_STRUCTURED_OUTPUT_RELIABILITY=medium
# MALV_CPU_TIER_MULTIMODAL_SUPPORTED=false
# MALV_CPU_TIER_MAX_CONCURRENT_INFER=0
#
# MALV_GPU_TIER_CAPABILITY_CLASS=frontier
# MALV_GPU_TIER_MAX_PROMPT_CHARS=200000
# MALV_GPU_TIER_MAX_CONTEXT_CHARS=500000
# MALV_GPU_TIER_REASONING_DEPTH_MAX=frontier
# MALV_GPU_TIER_LATENCY_PROFILE=balanced
# MALV_GPU_TIER_STRUCTURED_OUTPUT_RELIABILITY=high
# MALV_GPU_TIER_MULTIMODAL_SUPPORTED=true
# Legacy: MALV_LIGHTWEIGHT_MAX_* still overrides when MALV_CPU_TIER_MAX_* unset.

# Phase 4 — adaptive learning (signals + thresholds). Set false to disable capture and adaptive nudges.
# MALV_LEARNING_ENABLED=true

# Adaptive chat output token budgeting (optional; defaults match production-safe behavior)
# MALV_CHAT_MAXTOKENS_MIN=320
# MALV_CHAT_MAXTOKENS_BASE=640
# MALV_CHAT_MAXTOKENS_MAX=2048
# MALV_CHAT_MAXTOKENS_STRUCTURED_BOOST=220
# MALV_CHAT_MAXTOKENS_CONVERSATION_BOOST=28
# MALV_CHAT_MAXTOKENS_BREVITY_PENALTY=120
