{
  "name": "@malv/api",
  "private": true,
  "version": "0.1.0",
  "type": "commonjs",
  "scripts": {
    "dev": "nest start --watch --preserveWatchOutput",
    "build": "nest build",
    "start": "nest start",
    "migration:run": "node -r ts-node/register ../../node_modules/typeorm/cli.js -d src/db/data-source.ts migration:run",
    "migration:revert": "node -r ts-node/register ../../node_modules/typeorm/cli.js -d src/db/data-source.ts migration:revert",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"(lint to be added later)\"",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:mysql:integration": "MALV_RUN_MYSQL_INTEGRATION=1 jest malv-infra.mysql.integration --runInBand --testTimeout=180000"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.12",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.12",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.12",
    "@nestjs/platform-socket.io": "^10.4.12",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/websockets": "^10.3.10",
    "@types/multer": "^2.1.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.7",
    "image-size": "^2.0.2",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "mysql2": "^3.11.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-parse": "^2.4.5",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.2",
    "@nestjs/schematics": "^10.1.3",
    "@nestjs/testing": "^10.4.22",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/supertest": "^6.0.2",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "testcontainers": "^10.28.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
