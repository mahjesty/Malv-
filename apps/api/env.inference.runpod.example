# -----------------------------------------------------------------------------
# RunPod vLLM (OpenAI-compatible wire) as the primary inference chain for MALV chat.
# Merge into repo ROOT .env and/or apps/api/.env. The API serves effective config
# to beast-worker; worker and API must agree on these values (or use DB override).
# -----------------------------------------------------------------------------

# MALV-owned primary chain (preferred source of truth)
MALV_INFERENCE_PROVIDER=openai_compatible
MALV_INFERENCE_BASE_URL=https://9xtaa437gbp7su-8000.proxy.runpod.net/v1
MALV_INFERENCE_MODEL=Qwen2.5-7B-Instruct
MALV_INFERENCE_API_KEY=placeholder
# Recommended for RunPod: env is the sole runtime authority (no hidden DB override vs worker).
# MALV_INFERENCE_PRIMARY_AUTHORITY=env
# MALV_INFERENCE_TIMEOUT_MS=120000

# Legacy primary-chain aliases (optional if MALV_INFERENCE_* are set)
# INFERENCE_BACKEND=openai_compatible
# INFERENCE_BASE_URL=https://9xtaa437gbp7su-8000.proxy.runpod.net/v1
# INFERENCE_MODEL=Qwen2.5-7B-Instruct
# INFERENCE_API_KEY=placeholder

# Production: do not silently fall back to the template provider unless intended
# INFERENCE_FALLBACK_ENABLED=false
# INFERENCE_FALLBACK_POLICY=disabled

# Older vendor-prefixed aliases (still read if newer vars unset)
# MALV_OPENAI_COMPAT_BASE_URL=https://9xtaa437gbp7su-8000.proxy.runpod.net/v1
# MALV_INFERENCE_BACKEND=openai_compatible

# -----------------------------------------------------------------------------
# Disconnect API-side local CPU llama-server (this PC / localhost:8081) from chat
# -----------------------------------------------------------------------------
MALV_LOCAL_CPU_INFERENCE_ENABLED=false
MALV_LOCAL_CPU_INFERENCE_DISABLE_CHAT_PATH=true
# Legacy: MALV_LOCAL_INFERENCE_ENABLED=false / MALV_LOCAL_INFERENCE_DISABLE_CHAT_PATH=true

# Do not route chat turns to beast-worker lightweight_local (separate CPU sidecar URL)
MALV_LIGHTWEIGHT_INFERENCE_ENABLED=false

# Worker should treat remote GPU/primary chain as the live path (defaults are OK)
# MALV_GPU_TIER_ENABLED=true
# MALV_GPU_TIER_PROBE_WORKER_HEALTH=true

# Beast-worker process: must reach the API for effective config, and the network for RunPod
# BEAST_WORKER_BASE_URL=http://127.0.0.1:9090
# MALV_API_BASE_URL=http://127.0.0.1:8080
